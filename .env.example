# Copy to .env and adjust. Never commit .env.

DB_PASSWORD=change_me_appempire
MARIADB_ROOT_PASSWORD=root_change_me
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_secret_change

# Admin login (no DB) — use scripts/hash_password.py to generate EMPIRE_PASSWORD_HASH
EMPIRE_AUTH_USERNAME=admin
EMPIRE_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...replace_with_output_of_hash_password_script

# 32+ random bytes as hex or base64
EMPIRE_JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars

# OpenClaw : volume monté dans le conteneur backend (cron, Nerve filesystem, etc.)
# Sans variable : ./.docker-openclaw à la racine du projet (compatible macOS). VPS : décommenter et fixer le chemin réel.
# OPENCLAW_HOST_PATH=/home/ubuntu/.openclaw
# OPENCLAW_DIR=/openclaw-data
# (Optionnel) ancienne intégration par HTTP — non requise si les fichiers sont montés
# OPENCLAW_GATEWAY_URL=
# OPENCLAW_GATEWAY_TOKEN=

# Nerve center : fichiers OpenClaw (SOUL.md, MEMORY.md, …) vs copie en base
# NERVE_STORAGE=database
# NERVE_STORAGE=filesystem
# Carte agent_id -> dossier workspace relatif à OPENCLAW_DIR (JSON sur une ligne)
# OPENCLAW_NERVE_AGENT_PATHS={"marlene":"workspace/marlene-cron"}
# Si un agent n’est pas dans la carte, repli (optionnel) :
# OPENCLAW_NERVE_PATH_TEMPLATE=workspace/{agent_id}
